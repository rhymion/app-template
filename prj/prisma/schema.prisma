// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Corresponding Prisma version: 7

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Common models
// ============================================================

// Tenant — deployment-level partition (one SaaS customer = one tenant).
// See docs/multi-tenancy.md for the broader design.
//
// `creator_id` / `updater_id` are nullable because the bootstrap "default"
// tenant created by scripts/seed-its.ts and the 1.5 migration script
// exists before any user does. Normal admin-created tenants always
// carry both ids.
model tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  // 'active' = sign-ins permitted; 'suspended' = sign-ins rejected by the
  // signIn callback (wired in ticket 1.4). Stored as a string for forward
  // compatibility with additional states ('archived', etc.).
  status     String   @default("active")
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String?
  creator    user?    @relation("TenantCreator", fields: [creator_id], references: [id])
  updater_id String?
  updater    user?    @relation("TenantUpdater", fields: [updater_id], references: [id])
  users      user[]   @relation("UserTenant")

  @@index([creator_id])
}

model user {
  id                        String              @id @default(cuid())
  name                      String
  email                     String              @unique
  password                  String?
  api_key                   String?
  image                     String?
  emailVerified             DateTime?
  // 1.2: every user belongs to exactly one tenant. The `@default("default")`
  // matches the bootstrap tenant id seeded by scripts/seed-its.ts and the
  // 1.5 backfill migration, so write paths that pre-date the generator
  // updates in Phase 3 keep working until they thread `tenant_id` through
  // explicitly. onDelete: Restrict — accidental tenant deletion must not
  // cascade to users.
  tenant_id                 String              @default("default")
  tenant                    tenant              @relation("UserTenant", fields: [tenant_id], references: [id], onDelete: Restrict)
  plan_id                   String?
  plan                      plan?               @relation("UserPlan", fields: [plan_id], references: [id])
  sub_accounts              sub_account[]       @relation("UserSubAccounts")
  cry_posts                 cry_post[]          @relation("UserCryPosts")
  reactions                 reaction[]          @relation("UserReactions")
  tip_txs                   tip_tx[]            @relation("UserTipTxs")
  // MFA / TOTP (S5). `mfa_secret` is AES-256-GCM ciphertext produced by
  // lib/mfa/crypto.ts; `mfa_enabled` only flips true after a successful
  // first-code verification. `mfa_recovery_codes` is the back-relation
  // for the single-use codes.
  mfa_secret                String?
  mfa_enabled               Boolean             @default(false)
  mfa_recovery_codes        mfa_recovery_code[]
  accounts                  Account[]
  sessions                  Session[]
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user  @relation("UserCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user  @relation("UserUpdater", fields: [updater_id], references: [id])

  roles         role[]         @relation("UserRoles")
  organizations organization[] @relation("UserOrganizations")

  created_users  user[]  @relation("UserCreator")
  updated_users  user[]  @relation("UserUpdater")
  created_roles          role[]          @relation("RoleCreator")
  updated_roles          role[]          @relation("RoleUpdater")
  created_organizations  organization[]  @relation("OrganizationCreator")
  updated_organizations  organization[]  @relation("OrganizationUpdater")
  created_permissions    permission[]    @relation("PermissionCreator")
  updated_permissions    permission[]    @relation("PermissionUpdater")
  created_approval_flows  approval_flow[] @relation("ApprovalFlowCreator")
  updated_approval_flows  approval_flow[] @relation("ApprovalFlowUpdater")
  created_approval_historys  approval_history[] @relation("ApprovalHistoryCreator")
  created_approvables     approvable[]    @relation("ApprovableCreator")
  created_comments          comment[]        @relation("CommentCreator")
  created_dashboards        dashboard[]         @relation("DashboardCreator")
  updated_dashboards        dashboard[]         @relation("DashboardUpdater")
  created_tenants           tenant[]            @relation("TenantCreator")
  updated_tenants           tenant[]            @relation("TenantUpdater")
  created_works             work[]              @relation("WorkCreator")
  updated_works             work[]              @relation("WorkUpdater")
  created_characters        character[]         @relation("CharacterCreator")
  updated_characters        character[]         @relation("CharacterUpdater")
  created_scenes            scene[]             @relation("SceneCreator")
  updated_scenes            scene[]             @relation("SceneUpdater")
  created_musics            music[]             @relation("MusicCreator")
  updated_musics            music[]             @relation("MusicUpdater")
  created_creators          creator[]           @relation("CreatorCreator")
  updated_creators          creator[]           @relation("CreatorUpdater")
  created_channels          channel[]           @relation("ChannelCreator")
  updated_channels          channel[]           @relation("ChannelUpdater")
  created_plans             plan[]              @relation("PlanCreator")
  updated_plans             plan[]              @relation("PlanUpdater")

  @@index([api_key])
  @@index([creator_id])
  @@index([tenant_id])
}

model plan {
  id                      String   @id @default(cuid())
  tier                    Int
  reaction_kinds_allowed  Int
  sub_account_limit       Int
  can_view_paid_posts     Boolean
  users                   user[]   @relation("UserPlan")
  creator_id              String?
  creator                 user?    @relation("PlanCreator", fields: [creator_id], references: [id])
  updater_id              String?
  updater                 user?    @relation("PlanUpdater", fields: [updater_id], references: [id])
  created_at              DateTime @default(now()) @db.Timestamptz(0)
  updated_at              DateTime @updatedAt @db.Timestamptz(0)

  @@index([creator_id])
}

model sub_account {
  id              String   @id @default(cuid())
  parent_user_id  String
  parent_user     user     @relation("UserSubAccounts", fields: [parent_user_id], references: [id], onDelete: Cascade)
  nickname        String
  created_at      DateTime @default(now()) @db.Timestamptz(0)
  updated_at      DateTime @updatedAt @db.Timestamptz(0)

  @@index([parent_user_id])
}

model work {
  id                  String      @id @default(cuid())
  title               String
  pattern             Int
  status              Int
  characters          character[]
  scenes              scene[]
  channels            channel[]
  fc_links            fc_link[]
  creator_id          String?
  creator             user?       @relation("WorkCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?       @relation("WorkUpdater", fields: [updater_id], references: [id])
  created_at          DateTime    @default(now()) @db.Timestamptz(0)
  updated_at          DateTime    @updatedAt @db.Timestamptz(0)

  @@index([creator_id])
}

model character {
  id                  String      @id @default(cuid())
  name                String
  work_id             String
  work                work        @relation(fields: [work_id], references: [id], onDelete: Cascade)
  official_image      Boolean
  channels            channel[]
  scenes              scene[]     @relation("SceneCharacters")
  creators            creator[]   @relation("CreatorCharacters")
  fc_links            fc_link[]
  creator_id          String?
  creator             user?       @relation("CharacterCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?       @relation("CharacterUpdater", fields: [updater_id], references: [id])
  created_at          DateTime    @default(now()) @db.Timestamptz(0)
  updated_at          DateTime    @updatedAt @db.Timestamptz(0)

  @@index([work_id])
  @@index([creator_id])
}

model scene {
  id                  String      @id @default(cuid())
  label               String
  work_id             String
  work                work        @relation(fields: [work_id], references: [id], onDelete: Cascade)
  episode             String
  timestamp           String
  channels            channel[]
  characters          character[] @relation("SceneCharacters")
  music               music[]     @relation("SceneMusics")
  creators            creator[]   @relation("SceneCredits")
  creator_id          String?
  creator             user?       @relation("SceneCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?       @relation("SceneUpdater", fields: [updater_id], references: [id])
  created_at          DateTime    @default(now()) @db.Timestamptz(0)
  updated_at          DateTime    @updatedAt @db.Timestamptz(0)

  @@index([work_id])
  @@index([creator_id])
}

model music {
  id                  String      @id @default(cuid())
  title               String
  kind                Int
  scenes              scene[]     @relation("SceneMusics")
  composers           creator[]   @relation("ComposerMusics")
  credits             creator[]   @relation("CreditedMusics")
  fc_links            fc_link[]
  creator_id          String?
  creator             user?       @relation("MusicCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?       @relation("MusicUpdater", fields: [updater_id], references: [id])
  created_at          DateTime    @default(now()) @db.Timestamptz(0)
  updated_at          DateTime    @updatedAt @db.Timestamptz(0)

  @@index([creator_id])
}

model creator {
  id                  String      @id @default(cuid())
  name                String
  role                Int
  affiliation         Int
  voiced_characters   character[] @relation("CreatorCharacters")
  composed_musics     music[]     @relation("ComposerMusics")
  credited_musics     music[]     @relation("CreditedMusics")
  credited_scenes     scene[]     @relation("SceneCredits")
  creator_id          String?
  creator             user?       @relation("CreatorCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?       @relation("CreatorUpdater", fields: [updater_id], references: [id])
  created_at          DateTime    @default(now()) @db.Timestamptz(0)
  updated_at          DateTime    @updatedAt @db.Timestamptz(0)

  @@index([creator_id])
}

model channel {
  id                  String       @id @default(cuid())
  parent_id           String
  name                String
  kind                Int
  visibility          Int
  work_id             String?
  work                work?        @relation(fields: [work_id], references: [id], onDelete: Cascade)
  character_id        String?
  character           character?   @relation(fields: [character_id], references: [id], onDelete: Cascade)
  scene_id            String?
  scene               scene?       @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  commentable_id      String?      @unique
  commentable         commentable? @relation("ChannelCommentable", fields: [commentable_id], references: [id])
  cry_posts           cry_post[]
  fc_links            fc_link[]
  creator_id          String?
  creator             user?        @relation("ChannelCreator", fields: [creator_id], references: [id])
  updater_id          String?
  updater             user?        @relation("ChannelUpdater", fields: [updater_id], references: [id])
  created_at          DateTime     @default(now()) @db.Timestamptz(0)
  updated_at          DateTime     @updatedAt @db.Timestamptz(0)

  @@index([work_id])
  @@index([character_id])
  @@index([scene_id])
  @@index([creator_id])
}

model fc_link {
  id             String      @id @default(cuid())
  name           String
  url            String
  contract_split_id String?
  work_id        String?
  work           work?       @relation(fields: [work_id], references: [id], onDelete: Cascade)
  character_id   String?
  character      character?  @relation(fields: [character_id], references: [id], onDelete: Cascade)
  music_id       String?
  music          music?      @relation(fields: [music_id], references: [id], onDelete: Cascade)
  channel_id     String?
  channel        channel?    @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  created_at     DateTime    @default(now()) @db.Timestamptz(0)
  updated_at     DateTime    @updatedAt @db.Timestamptz(0)

  @@index([work_id])
  @@index([character_id])
  @@index([music_id])
  @@index([channel_id])
}

model cry_post {
  id              String    @id @default(cuid())
  body            String
  author_user_id  String
  author          user      @relation("UserCryPosts", fields: [author_user_id], references: [id], onDelete: Cascade)
  channel_id      String
  channel         channel   @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  tip_txs         tip_tx[]
  created_at      DateTime  @default(now()) @db.Timestamptz(0)
  updated_at      DateTime  @updatedAt @db.Timestamptz(0)

  @@index([author_user_id])
  @@index([channel_id])
}

model reaction {
  id          String   @id @default(cuid())
  type        Int
  user_id     String
  user        user     @relation("UserReactions", fields: [user_id], references: [id], onDelete: Cascade)
  comment_id  String
  comment     comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  created_at  DateTime @default(now()) @db.Timestamptz(0)
  updated_at  DateTime @updatedAt @db.Timestamptz(0)

  @@unique([comment_id, user_id, type])
  @@index([user_id])
  @@index([comment_id])
}

model tip_tx {
  id                String   @id @default(cuid())
  gross_amount      Int
  operator_fee      Int
  payment_fee       Int
  contract_split_id String
  status            Int
  user_id           String
  user              user     @relation("UserTipTxs", fields: [user_id], references: [id], onDelete: Cascade)
  cry_post_id       String
  cry_post          cry_post @relation(fields: [cry_post_id], references: [id], onDelete: Cascade)
  created_at        DateTime @default(now()) @db.Timestamptz(0)
  updated_at        DateTime @updatedAt @db.Timestamptz(0)

  @@index([user_id])
  @@index([cry_post_id])
}

model role {
  id          String  @id @default(cuid())
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(0)
  updated_at  DateTime @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user @relation("RoleCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user @relation("RoleUpdater", fields: [updater_id], references: [id])

  users user[] @relation("UserRoles")
  permissions   permission[]
  requestor_approval_flows approval_flow[] @relation("ApprovalFlowRequestorRole")
  approver_approval_flows  approval_flow[] @relation("ApprovalFlowApproverRole")
  @@index([creator_id])
}

model organization {
  id          String  @id @default(cuid())
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(0)
  updated_at  DateTime @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user @relation("OrganizationCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user @relation("OrganizationUpdater", fields: [updater_id], references: [id])

  users user[] @relation("UserOrganizations")
  @@index([creator_id])
}

model permission {
  id         String  @id @default(cuid())
  name       String
  role_id    String?
  role       role?   @relation(fields: [role_id], references: [id], onDelete: Cascade)
  create     Boolean
  read       Boolean
  update     Boolean
  delete     Boolean
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user @relation("PermissionCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user @relation("PermissionUpdater", fields: [updater_id], references: [id])

  @@unique([name, role_id])
  @@index([creator_id])
}

model approvable {
  id               String   @id @default(cuid())
  creator_id       String?
  creator          user? @relation("ApprovableCreator", fields: [creator_id], references: [id])
  approval_requests approval_request[]
  @@index([creator_id])
}

model approval_flow {
  id               String   @id @default(cuid())
  entity_name      String
  requestor_role_id String?
  requestor_role   role?    @relation("ApprovalFlowRequestorRole", fields: [requestor_role_id], references: [id])
  approver_role_id String
  approver_role    role     @relation("ApprovalFlowApproverRole", fields: [approver_role_id], references: [id])
  approval_requests approval_request[]
  preceded_by      approval_flow[] @relation("ApprovalFlowOrder")
  followed_by      approval_flow[] @relation("ApprovalFlowOrder")
  created_at       DateTime @default(now()) @db.Timestamptz(0)
  updated_at       DateTime @updatedAt @db.Timestamptz(0)
  creator_id       String
  creator          user @relation("ApprovalFlowCreator", fields: [creator_id], references: [id])
  updater_id       String
  updater          user @relation("ApprovalFlowUpdater", fields: [updater_id], references: [id])
  @@index([creator_id])
}

model approval_request {
  id               String   @id @default(cuid())
  approvable_id    String
  approvable       approvable @relation(fields: [approvable_id], references: [id], onDelete: Cascade)
  approval_flow_id String
  approval_flow    approval_flow @relation(fields: [approval_flow_id], references: [id])
  status           Int      @default(0)
  approval_histories approval_history[]
  created_at       DateTime @default(now()) @db.Timestamptz(0)
  updated_at       DateTime @updatedAt @db.Timestamptz(0)
}

model approval_history {
  id               String   @id @default(cuid())
  approval_request_id String
  approval_request approval_request @relation(fields: [approval_request_id], references: [id], onDelete: Cascade)
  pre_status       Int
  post_status      Int
  message          String?
  created_at       DateTime @default(now()) @db.Timestamptz(0)
  updated_at       DateTime @updatedAt @db.Timestamptz(0)
  creator_id       String
  creator          user @relation("ApprovalHistoryCreator", fields: [creator_id], references: [id])
  @@index([creator_id])
}

model commentable {
  id        String    @id @default(cuid())
  comments  comment[]
  channel   channel?  @relation("ChannelCommentable")
}

model comment {
  id             String      @id @default(cuid())
  message        String
  commentable_id String
  commentable    commentable @relation(fields: [commentable_id], references: [id], onDelete: Cascade)
  reactions      reaction[]
  created_at     DateTime    @default(now()) @db.Timestamptz(0)
  updated_at     DateTime    @updatedAt @db.Timestamptz(0)
  creator_id     String
  creator        user @relation("CommentCreator", fields: [creator_id], references: [id])
  @@index([creator_id])
}

model attachable {
  id          String       @id @default(cuid())
  attachments attachment[]
}

model attachment {
  id            String     @id @default(cuid())
  type          Int        @default(0)
  order         Int        @default(0)
  name          String
  path          String
  attachable_id String
  attachable    attachable @relation(fields: [attachable_id], references: [id], onDelete: Cascade)
  created_at    DateTime   @default(now()) @db.Timestamptz(0)
  updated_at    DateTime   @updatedAt @db.Timestamptz(0)
}

model dashboard {
  id         String             @id @default(cuid())
  name       String
  widgets    dashboard_widget[]
  created_at DateTime           @default(now()) @db.Timestamptz(0)
  updated_at DateTime           @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user               @relation("DashboardCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user               @relation("DashboardUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model dashboard_widget {
  id             String    @id @default(cuid())
  dashboard_id   String
  dashboard      dashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  name            String
  entity_name     String
  chart_type      Int
  group_by_field  String
  stack_mode      Int?
  series_field    String?
  group_by_bucket Int?
  filter_field    String?
  filter_value    String?
  order          Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamptz(0)
  updated_at     DateTime  @updatedAt @db.Timestamptz(0)
}

// Append-only audit trail for security-relevant events: auth lifecycle
// (sign-in/out, account creation, sign-in rejection) and CRUD on protected
// entities (roles, permissions, role assignments, …). Rows must outlive the
// user they reference, so `actor_user_id` is a plain string with no FK
// constraint — deleting a user does not cascade-delete their audit history.
// `actor_user_id` is nullable because some events (rejected sign-in with an
// unknown email, system-triggered actions) have no resolved actor.
model audit_log {
  id            String   @id @default(cuid())
  actor_user_id String?
  action        String
  target_table  String?
  target_id     String?
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamptz(0)

  @@index([actor_user_id])
  @@index([target_table, target_id])
  @@index([created_at])
}

// Single-use MFA recovery codes (S5). One row per generated code.
// `code_hash` is bcrypt of the *normalized* plaintext (uppercased, dashes
// stripped) so verification doesn't have to guess at the user's
// punctuation habits. `used_at` is set on first successful verification
// and the row is then dead weight — kept around so a future "MFA audit
// log" page can show "X recovery codes used" without joining elsewhere.
model mfa_recovery_code {
  id         String    @id @default(cuid())
  user_id    String
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  code_hash  String
  used_at    DateTime? @db.Timestamptz(0)
  created_at DateTime  @default(now()) @db.Timestamptz(0)

  @@index([user_id])
}

// ─────────────────────────────────────────────────────────────────────────────
// NextAuth (@next-auth/prisma-adapter) auxiliary tables.
//
// `Account`, `Session`, `VerificationToken` are PascalCase by NextAuth
// contract — the adapter accesses them as `prisma.account`, `prisma.session`,
// `prisma.verificationToken`, which the Prisma client derives by
// lower-casing the first letter of the model name.
//
// The `User` model required by PrismaAdapter is *the same row* as our
// domain `user` (see `model user` above) — `prisma.user` resolves to that
// model since Prisma lower-cases the model name. The adapter writes
// `emailVerified` / `image` directly into the merged table; the
// `user_account ↔ User` mirror that existed in earlier versions is gone.
//
// `session: { strategy: 'jwt' }` is kept in auth.ts so the Credentials
// provider keeps working:
//   - `Account` rows are written on every OAuth sign-in (identity stability
//     by providerAccountId).
//   - `Session` is unused today; lights up under Auth.js v5 (database
//     sessions).
//   - `VerificationToken` is unused until an Email/magic-link provider is
//     added.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
