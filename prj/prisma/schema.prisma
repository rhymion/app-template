// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Corresponding Prisma version: 7

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Common models
// ============================================================

// Tenant — deployment-level partition (one SaaS customer = one tenant).
// See docs/multi-tenancy.md for the broader design.
//
// `creator_id` / `updater_id` are nullable because the bootstrap "default"
// tenant created by scripts/seed-its.ts and the 1.5 migration script
// exists before any user does. Normal admin-created tenants always
// carry both ids.
model tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  // 'active' = sign-ins permitted; 'suspended' = sign-ins rejected by the
  // signIn callback (wired in ticket 1.4). Stored as a string for forward
  // compatibility with additional states ('archived', etc.).
  status     String   @default("active")
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String?
  creator    user?    @relation("TenantCreator", fields: [creator_id], references: [id])
  updater_id String?
  updater    user?    @relation("TenantUpdater", fields: [updater_id], references: [id])
  users      user[]   @relation("UserTenant")

  @@index([creator_id])
}

model user {
  id                        String              @id @default(cuid())
  name                      String
  email                     String              @unique
  password                  String?
  api_key                   String?
  image                     String?
  emailVerified             DateTime?
  // 1.2: every user belongs to exactly one tenant. The `@default("default")`
  // matches the bootstrap tenant id seeded by scripts/seed-its.ts and the
  // 1.5 backfill migration, so write paths that pre-date the generator
  // updates in Phase 3 keep working until they thread `tenant_id` through
  // explicitly. onDelete: Restrict — accidental tenant deletion must not
  // cascade to users.
  tenant_id                 String              @default("default")
  tenant                    tenant              @relation("UserTenant", fields: [tenant_id], references: [id], onDelete: Restrict)
  // MFA / TOTP (S5). `mfa_secret` is AES-256-GCM ciphertext produced by
  // lib/mfa/crypto.ts; `mfa_enabled` only flips true after a successful
  // first-code verification. `mfa_recovery_codes` is the back-relation
  // for the single-use codes.
  mfa_secret                String?
  mfa_enabled               Boolean             @default(false)
  mfa_recovery_codes        mfa_recovery_code[]
  accounts                  Account[]
  sessions                  Session[]
  created_at                DateTime            @default(now()) @db.Timestamptz(0)
  updated_at                DateTime            @updatedAt @db.Timestamptz(0)
  creator_id                String
  creator                   user                @relation("UserCreator", fields: [creator_id], references: [id])
  updater_id                String
  updater                   user                @relation("UserUpdater", fields: [updater_id], references: [id])
  roles                     role[]              @relation("UserRoles")
  shift_templates           shift_template[]    @relation("ShiftTemplateUser")
  shifts                    shift[]             @relation("ShiftUser")
  organizations             organization[]      @relation("UserOrganizations")
  purchase_orders           purchase_order[]    @relation("Buyer")
  created_db_tables         db_table[]          @relation("DbTableCreator")
  updated_db_tables         db_table[]          @relation("DbTableUpdater")
  created_xxxxx_xxxxxs      xxxxx_xxxxx[]       @relation("XxxxxXxxxxCreator")
  updated_xxxxx_xxxxxs      xxxxx_xxxxx[]       @relation("XxxxxXxxxxUpdater")
  created_parent1s          parent1[]           @relation("Parent1Creator")
  updated_parent1s          parent1[]           @relation("Parent1Updater")
  created_parent_onlys      parent_only[]       @relation("ParentOnlyCreator")
  updated_parent_onlys      parent_only[]       @relation("ParentOnlyUpdater")
  created_permissions       permission[]        @relation("PermissionCreator")
  updated_permissions       permission[]        @relation("PermissionUpdater")
  created_procedures        procedure[]         @relation("ProcedureCreator")
  updated_procedures        procedure[]         @relation("ProcedureUpdater")
  assigned_procedures       procedure[]         @relation("ProcedureAssignee")
  created_roles             role[]              @relation("RoleCreator")
  updated_roles             role[]              @relation("RoleUpdater")
  created_organizations     organization[]      @relation("OrganizationCreator")
  updated_organizations     organization[]      @relation("OrganizationUpdater")
  created_users             user[]              @relation("UserCreator")
  updated_users             user[]              @relation("UserUpdater")
  created_resources         resource[]          @relation("ResourceCreator")
  updated_resources         resource[]          @relation("ResourceUpdater")
  created_bookings          booking[]           @relation("BookingCreator")
  updated_bookings          booking[]           @relation("BookingUpdater")
  created_shift_templates   shift_template[]    @relation("ShiftTemplateCreator")
  updated_shift_templates   shift_template[]    @relation("ShiftTemplateUpdater")
  created_shifts            shift[]             @relation("ShiftCreator")
  updated_shifts            shift[]             @relation("ShiftUpdater")
  created_products          product[]           @relation("ProductCreator")
  updated_products          product[]           @relation("ProductUpdater")
  created_inventories       inventory[]         @relation("InventoryCreator")
  updated_inventories       inventory[]         @relation("InventoryUpdater")
  created_inventory_allocations inventory_allocation[] @relation("InventoryAllocationCreator")
  updated_inventory_allocations inventory_allocation[] @relation("InventoryAllocationUpdater")
  created_purchase_orders   purchase_order[]    @relation("PurchaseOrderCreator")
  updated_purchase_orders   purchase_order[]    @relation("PurchaseOrderUpdater")
  created_comments          comment[]           @relation("CommentCreator")
  leave_requests            leave_request[]     @relation("LeaveRequestUser")
  created_leave_requests    leave_request[]     @relation("LeaveRequestCreator")
  updated_leave_requests    leave_request[]     @relation("LeaveRequestUpdater")
  created_approval_flows    approval_flow[]     @relation("ApprovalFlowCreator")
  updated_approval_flows    approval_flow[]     @relation("ApprovalFlowUpdater")
  created_approval_historys approval_history[]  @relation("ApprovalHistoryCreator")
  created_approvables       approvable[]        @relation("ApprovableCreator")
  created_dashboards        dashboard[]         @relation("DashboardCreator")
  updated_dashboards        dashboard[]         @relation("DashboardUpdater")
  created_tenants               tenant[]            @relation("TenantCreator")
  updated_tenants               tenant[]            @relation("TenantUpdater")
  created_supply_pools          supply_pool[]       @relation("SupplyPoolCreator")
  updated_supply_pools          supply_pool[]       @relation("SupplyPoolUpdater")
  created_supply_requests       supply_request[]    @relation("SupplyRequestCreator")
  updated_supply_requests       supply_request[]    @relation("SupplyRequestUpdater")
  created_room_types            room_type[]         @relation("RoomTypeCreator")
  updated_room_types            room_type[]         @relation("RoomTypeUpdater")
  created_rooms                 room[]              @relation("RoomCreator")
  updated_rooms                 room[]              @relation("RoomUpdater")
  created_room_reservations             room_reservation[]         @relation("RoomReservationCreator")
  updated_room_reservations             room_reservation[]         @relation("RoomReservationUpdater")
  created_receiving_purchase_orders     receiving_purchase_order[] @relation("ReceivingPurchaseOrderCreator")
  updated_receiving_purchase_orders     receiving_purchase_order[] @relation("ReceivingPurchaseOrderUpdater")
  created_receiving_asns                receiving_asn[]            @relation("ReceivingAsnCreator")
  updated_receiving_asns                receiving_asn[]            @relation("ReceivingAsnUpdater")
  created_receiving_receipts            receiving_receipt[]        @relation("ReceivingReceiptCreator")
  updated_receiving_receipts            receiving_receipt[]        @relation("ReceivingReceiptUpdater")

  @@index([api_key])
  @@index([creator_id])
  @@index([tenant_id])
}

model role {
  id                       String          @id @default(cuid())
  name                     String
  description              String?
  created_at               DateTime        @default(now()) @db.Timestamptz(0)
  updated_at               DateTime        @updatedAt @db.Timestamptz(0)
  creator_id               String
  creator                  user            @relation("RoleCreator", fields: [creator_id], references: [id])
  updater_id               String
  updater                  user            @relation("RoleUpdater", fields: [updater_id], references: [id])
  users                    user[]          @relation("UserRoles")
  permissions              permission[]
  requestor_approval_flows approval_flow[] @relation("ApprovalFlowRequestorRole")
  approver_approval_flows  approval_flow[] @relation("ApprovalFlowApproverRole")

  @@index([creator_id])
}

model organization {
  id          String     @id @default(cuid())
  name        String
  description String?
  created_at  DateTime   @default(now()) @db.Timestamptz(0)
  updated_at  DateTime   @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user       @relation("OrganizationCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user       @relation("OrganizationUpdater", fields: [updater_id], references: [id])
  users       user[]     @relation("UserOrganizations")
  parent1s    parent1[]
  resources   resource[]

  @@index([creator_id])
}

model permission {
  id         String   @id @default(cuid())
  name       String
  role_id    String?
  role       role?    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  create     Boolean
  read       Boolean
  update     Boolean
  delete     Boolean
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user     @relation("PermissionCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user     @relation("PermissionUpdater", fields: [updater_id], references: [id])

  @@unique([name, role_id])
  @@index([creator_id])
}

model approvable {
  id                String             @id @default(cuid())
  creator_id        String?
  creator           user?              @relation("ApprovableCreator", fields: [creator_id], references: [id])
  approval_requests approval_request[]
  leave_request     leave_request?

  @@index([creator_id])
}

model approval_flow {
  id                String             @id @default(cuid())
  entity_name       String
  requestor_role_id String?
  requestor_role    role?              @relation("ApprovalFlowRequestorRole", fields: [requestor_role_id], references: [id])
  approver_role_id  String
  approver_role     role               @relation("ApprovalFlowApproverRole", fields: [approver_role_id], references: [id])
  approval_requests approval_request[]
  preceded_by       approval_flow[]    @relation("ApprovalFlowOrder")
  followed_by       approval_flow[]    @relation("ApprovalFlowOrder")
  created_at        DateTime           @default(now()) @db.Timestamptz(0)
  updated_at        DateTime           @updatedAt @db.Timestamptz(0)
  creator_id        String
  creator           user               @relation("ApprovalFlowCreator", fields: [creator_id], references: [id])
  updater_id        String
  updater           user               @relation("ApprovalFlowUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model approval_request {
  id                 String             @id @default(cuid())
  approvable_id      String
  approvable         approvable         @relation(fields: [approvable_id], references: [id], onDelete: Cascade)
  approval_flow_id   String
  approval_flow      approval_flow      @relation(fields: [approval_flow_id], references: [id])
  status             Int                @default(0)
  approval_histories approval_history[]
  created_at         DateTime           @default(now()) @db.Timestamptz(0)
  updated_at         DateTime           @updatedAt @db.Timestamptz(0)
}

model approval_history {
  id                  String           @id @default(cuid())
  approval_request_id String
  approval_request    approval_request @relation(fields: [approval_request_id], references: [id], onDelete: Cascade)
  pre_status          Int
  post_status         Int
  message             String?
  created_at          DateTime         @default(now()) @db.Timestamptz(0)
  updated_at          DateTime         @updatedAt @db.Timestamptz(0)
  creator_id          String
  creator             user             @relation("ApprovalHistoryCreator", fields: [creator_id], references: [id])

  @@index([creator_id])
}

model commentable {
  id       String    @id @default(cuid())
  comments comment[]
  db_table db_table?
}

model comment {
  id             String      @id @default(cuid())
  message        String
  commentable_id String
  commentable    commentable @relation(fields: [commentable_id], references: [id], onDelete: Cascade)
  created_at     DateTime    @default(now()) @db.Timestamptz(0)
  updated_at     DateTime    @updatedAt @db.Timestamptz(0)
  creator_id     String
  creator        user        @relation("CommentCreator", fields: [creator_id], references: [id])

  @@index([creator_id])
}

model attachable {
  id          String       @id @default(cuid())
  attachments attachment[]
  resource    resource?
  product     product?
}

model attachment {
  id            String     @id @default(cuid())
  type          Int        @default(0)
  order         Int        @default(0)
  name          String
  path          String
  attachable_id String
  attachable    attachable @relation(fields: [attachable_id], references: [id], onDelete: Cascade)
  created_at    DateTime   @default(now()) @db.Timestamptz(0)
  updated_at    DateTime   @updatedAt @db.Timestamptz(0)
}

model dashboard {
  id         String             @id @default(cuid())
  name       String
  widgets    dashboard_widget[]
  created_at DateTime           @default(now()) @db.Timestamptz(0)
  updated_at DateTime           @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user               @relation("DashboardCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user               @relation("DashboardUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model dashboard_widget {
  id             String    @id @default(cuid())
  dashboard_id   String
  dashboard      dashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade)
  name            String
  entity_name     String
  chart_type      Int
  group_by_field  String
  stack_mode      Int?
  series_field    String?
  group_by_bucket Int?
  filter_field    String?
  filter_value    String?
  order          Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamptz(0)
  updated_at     DateTime  @updatedAt @db.Timestamptz(0)
}

// Append-only audit trail for security-relevant events: auth lifecycle
// (sign-in/out, account creation, sign-in rejection) and CRUD on protected
// entities (roles, permissions, role assignments, …). Rows must outlive the
// user they reference, so `actor_user_id` is a plain string with no FK
// constraint — deleting a user does not cascade-delete their audit history.
// `actor_user_id` is nullable because some events (rejected sign-in with an
// unknown email, system-triggered actions) have no resolved actor.
model audit_log {
  id            String   @id @default(cuid())
  actor_user_id String?
  action        String
  target_table  String?
  target_id     String?
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamptz(0)

  @@index([actor_user_id])
  @@index([target_table, target_id])
  @@index([created_at])
}

// Single-use MFA recovery codes (S5). One row per generated code.
// `code_hash` is bcrypt of the *normalized* plaintext (uppercased, dashes
// stripped) so verification doesn't have to guess at the user's
// punctuation habits. `used_at` is set on first successful verification
// and the row is then dead weight — kept around so a future "MFA audit
// log" page can show "X recovery codes used" without joining elsewhere.
model mfa_recovery_code {
  id         String    @id @default(cuid())
  user_id    String
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  code_hash  String
  used_at    DateTime? @db.Timestamptz(0)
  created_at DateTime  @default(now()) @db.Timestamptz(0)

  @@index([user_id])
}

// ─────────────────────────────────────────────────────────────────────────────
// NextAuth (@next-auth/prisma-adapter) auxiliary tables.
//
// `Account`, `Session`, `VerificationToken` are PascalCase by NextAuth
// contract — the adapter accesses them as `prisma.account`, `prisma.session`,
// `prisma.verificationToken`, which the Prisma client derives by
// lower-casing the first letter of the model name.
//
// The `User` model required by PrismaAdapter is *the same row* as our
// domain `user` (see `model user` above) — `prisma.user` resolves to that
// model since Prisma lower-cases the model name. The adapter writes
// `emailVerified` / `image` directly into the merged table; the
// `user_account ↔ User` mirror that existed in earlier versions is gone.
//
// `session: { strategy: 'jwt' }` is kept in auth.ts so the Credentials
// provider keeps working:
//   - `Account` rows are written on every OAuth sign-in (identity stability
//     by providerAccountId).
//   - `Session` is unused today; lights up under Auth.js v5 (database
//     sessions).
//   - `VerificationToken` is unused until an Email/magic-link provider is
//     added.
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model db_table {
  id             String      @id @default(cuid())
  name           String      @unique
  description    String?
  commentable_id String      @unique
  commentable    commentable @relation(fields: [commentable_id], references: [id], onDelete: Cascade)
  created_at     DateTime    @default(now()) @db.Timestamptz(0)
  updated_at     DateTime    @updatedAt @db.Timestamptz(0)
  creator_id     String
  creator        user        @relation("DbTableCreator", fields: [creator_id], references: [id])
  updater_id     String
  updater        user        @relation("DbTableUpdater", fields: [updater_id], references: [id])
  fields         field[]     @relation("ParentTable")
  referenced_by  field[]     @relation("ReferenceTable")

  @@index([creator_id])
}

model field {
  id           String    @id @default(cuid())
  name         String
  type         String
  db_table_id  String
  db_table     db_table  @relation("ParentTable", fields: [db_table_id], references: [id], onDelete: Cascade)
  reference_id String?
  reference    db_table? @relation("ReferenceTable", fields: [reference_id], references: [id])
  max_length   Int
  max          Int?
  regex        String?
  required     Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.Timestamptz(0)
  updated_at   DateTime  @updatedAt @db.Timestamptz(0)
}

model xxxxx_xxxxx {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  team         String?
  created_at   DateTime      @default(now()) @db.Timestamptz(0)
  updated_at   DateTime      @updatedAt @db.Timestamptz(0)
  creator_id   String
  creator      user          @relation("XxxxxXxxxxCreator", fields: [creator_id], references: [id])
  updater_id   String
  updater      user          @relation("XxxxxXxxxxUpdater", fields: [updater_id], references: [id])
  yyyyy_yyyyys yyyyy_yyyyy[]

  @@index([creator_id])
}

model yyyyy_yyyyy {
  id             String      @id @default(cuid())
  name           String
  type           String
  xxxxx_xxxxx_id String
  xxxxx_xxxxx    xxxxx_xxxxx @relation(fields: [xxxxx_xxxxx_id], references: [id], onDelete: Cascade)
  max_length     Int?
  max            Int?
  regex          String?
  required       Boolean     @default(true)
  written_by     String
  created_at     DateTime    @default(now()) @db.Timestamptz(0)
  updated_at     DateTime    @updatedAt @db.Timestamptz(0)
}

model parent1 {
  id              String           @id @default(cuid())
  name            String           @unique
  organization_id String
  organization    organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  description     String?
  price           Int
  due_date        DateTime         @db.Timestamptz(0)
  image_url       String?
  created_at      DateTime         @default(now()) @db.Timestamptz(0)
  updated_at      DateTime         @updatedAt @db.Timestamptz(0)
  creator_id      String
  creator         user             @relation("Parent1Creator", fields: [creator_id], references: [id])
  updater_id      String
  updater         user             @relation("Parent1Updater", fields: [updater_id], references: [id])
  parent1_child1s parent1_child1[]
  parent1_child2s parent1_child2[]
  parent1_lists   parent1_list[]

  @@index([creator_id])
  @@index([organization_id])
}

model parent1_child1 {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  name       String
  type       String
  parent1_id String
  parent1    parent1  @relation(fields: [parent1_id], references: [id], onDelete: Cascade)
  max_length Int?
  max        Int?
  regex      String?
  required   Boolean  @default(true)
  written_by String
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
}

model parent1_child2 {
  id         String    @id @default(cuid())
  name       String
  parent1_id String
  parent1    parent1   @relation(fields: [parent1_id], references: [id], onDelete: Cascade)
  required   Boolean   @default(true)
  start_date DateTime? @db.Timestamptz(0)
  end_date   DateTime  @db.Timestamptz(0)
  created_at DateTime  @default(now()) @db.Timestamptz(0)
  updated_at DateTime  @updatedAt @db.Timestamptz(0)
}

model parent1_list {
  id         String   @id @default(cuid())
  name       String
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  parent1_id String
  parent1    parent1  @relation(fields: [parent1_id], references: [id], onDelete: Cascade)
}

model parent_only {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  login_time  DateTime? @db.Timestamptz(0)
  logout_time DateTime? @db.Timestamptz(0)
  created_at  DateTime  @default(now()) @db.Timestamptz(0)
  updated_at  DateTime  @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user      @relation("ParentOnlyCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user      @relation("ParentOnlyUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model procedure {
  id          String      @id @default(cuid())
  name        String
  description String?
  created_at  DateTime    @default(now()) @db.Timestamptz(0)
  updated_at  DateTime    @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user        @relation("ProcedureCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user        @relation("ProcedureUpdater", fields: [updater_id], references: [id])
  assignee_id String?
  assignee    user?       @relation("ProcedureAssignee", fields: [assignee_id], references: [id])
  parent_id   String?
  parent      procedure?  @relation("ParentChild", fields: [parent_id], references: [id])
  children    procedure[] @relation("ParentChild")
  preceded_by procedure[] @relation("BeforeAfter")
  followed_by procedure[] @relation("BeforeAfter")

  @@index([creator_id])
  @@index([assignee_id])
}

model resource {
  id              String       @id @default(cuid())
  name            String
  description     String?
  organization_id String
  organization    organization @relation(fields: [organization_id], references: [id])
  attachable_id   String       @unique
  attachable      attachable   @relation(fields: [attachable_id], references: [id])
  bookings        booking[]
  created_at      DateTime     @default(now()) @db.Timestamptz(0)
  updated_at      DateTime     @updatedAt @db.Timestamptz(0)
  creator_id      String
  creator         user         @relation("ResourceCreator", fields: [creator_id], references: [id])
  updater_id      String
  updater         user         @relation("ResourceUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
  @@index([organization_id])
}

model booking {
  id          String   @id @default(cuid())
  name        String
  resource_id String
  resource    resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  start_time  DateTime @db.Timestamptz(0)
  end_time    DateTime @db.Timestamptz(0)
  created_at  DateTime @default(now()) @db.Timestamptz(0)
  updated_at  DateTime @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user     @relation("BookingCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user     @relation("BookingUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model shift_template {
  id          String   @id @default(cuid())
  user_id     String
  user        user     @relation("ShiftTemplateUser", fields: [user_id], references: [id])
  day_of_week Int
  start_time  DateTime @db.Timetz(0)
  end_time    DateTime @db.Timetz(0)
  created_at  DateTime @default(now()) @db.Timestamptz(0)
  updated_at  DateTime @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user     @relation("ShiftTemplateCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user     @relation("ShiftTemplateUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model shift {
  id         String   @id @default(cuid())
  user_id    String
  user       user     @relation("ShiftUser", fields: [user_id], references: [id])
  start_time DateTime @db.Timestamptz(0)
  end_time   DateTime @db.Timestamptz(0)
  status     Int
  created_at DateTime @default(now()) @db.Timestamptz(0)
  updated_at DateTime @updatedAt @db.Timestamptz(0)
  creator_id String
  creator    user     @relation("ShiftCreator", fields: [creator_id], references: [id])
  updater_id String
  updater    user     @relation("ShiftUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model product {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  price              Int
  barcode            String?
  attachable_id      String              @unique
  attachable         attachable          @relation(fields: [attachable_id], references: [id])
  inventories                    inventory[]
  purchase_per_items             purchase_per_item[]
  receiving_purchase_order_lines receiving_purchase_order_line[]
  receiving_asn_lines            receiving_asn_line[]
  receiving_receipt_lines        receiving_receipt_line[]
  created_at                     DateTime                        @default(now()) @db.Timestamptz(0)
  updated_at         DateTime            @updatedAt @db.Timestamptz(0)
  creator_id         String
  creator            user                @relation("ProductCreator", fields: [creator_id], references: [id])
  updater_id         String
  updater            user                @relation("ProductUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model inventory {
  id                String    @id @default(cuid())
  product_id        String
  product           product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  quantity          Int
  reserved_quantity Int       @default(0)
  location          String?
  lot_number        String?
  expiration_date   DateTime?
  created_at        DateTime  @default(now()) @db.Timestamptz(0)
  updated_at        DateTime  @updatedAt @db.Timestamptz(0)
  creator_id        String
  creator           user      @relation("InventoryCreator", fields: [creator_id], references: [id])
  updater_id        String
  updater           user      @relation("InventoryUpdater", fields: [updater_id], references: [id])
  inventory_allocations inventory_allocation[]

  @@index([creator_id])
}

model purchase_order {
  id          String              @id @default(cuid())
  order_no    String
  customer_id String
  customer    user                @relation("Buyer", fields: [customer_id], references: [id])
  items       purchase_per_item[]
  created_at  DateTime            @default(now()) @db.Timestamptz(0)
  updated_at  DateTime            @updatedAt @db.Timestamptz(0)
  creator_id  String
  creator     user                @relation("PurchaseOrderCreator", fields: [creator_id], references: [id])
  updater_id  String
  updater     user                @relation("PurchaseOrderUpdater", fields: [updater_id], references: [id])
  inventory_allocations inventory_allocation[]

  @@index([creator_id])
}

model purchase_per_item {
  id                    String                 @id @default(cuid())
  purchase_order_id     String
  purchase_order        purchase_order         @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  product_id            String
  product               product                @relation(fields: [product_id], references: [id], onDelete: Cascade)
  quantity              Int
  price                 Int?
  inventory_allocations inventory_allocation[]
  created_at            DateTime               @default(now()) @db.Timestamptz(0)
  updated_at            DateTime               @updatedAt @db.Timestamptz(0)
}

model inventory_allocation {
  id                   String            @id @default(cuid())
  purchase_order_id    String
  purchase_order       purchase_order    @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  purchase_per_item_id String
  purchase_per_item    purchase_per_item @relation(fields: [purchase_per_item_id], references: [id], onDelete: Cascade)
  inventory_id         String
  inventory            inventory         @relation(fields: [inventory_id], references: [id], onDelete: Cascade)
  quantity             Int
  remaining_quantity   Int
  status               String
  created_at           DateTime          @default(now()) @db.Timestamptz(0)
  updated_at           DateTime          @updatedAt @db.Timestamptz(0)
  creator_id           String
  creator              user              @relation("InventoryAllocationCreator", fields: [creator_id], references: [id])
  updater_id           String
  updater              user              @relation("InventoryAllocationUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model leave_request {
  id            String     @id @default(cuid())
  user_id       String
  user          user       @relation("LeaveRequestUser", fields: [user_id], references: [id])
  start_date    DateTime   @db.Timestamptz(0)
  end_date      DateTime   @db.Timestamptz(0)
  reason        String
  approvable_id String     @unique
  approvable    approvable @relation(fields: [approvable_id], references: [id])
  created_at    DateTime   @default(now()) @db.Timestamptz(0)
  updated_at    DateTime   @updatedAt @db.Timestamptz(0)
  creator_id    String
  creator       user       @relation("LeaveRequestCreator", fields: [creator_id], references: [id])
  updater_id    String
  updater       user       @relation("LeaveRequestUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

// ============================================================
// Cell 2: count mode, no lines (supply_request example)
// ============================================================

model supply_pool {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  quantity           Int
  reserved_quantity  Int                 @default(0)
  supply_allocations supply_allocation[]
  created_at         DateTime            @default(now()) @db.Timestamptz(0)
  updated_at         DateTime            @updatedAt @db.Timestamptz(0)
  creator_id         String
  creator            user                @relation("SupplyPoolCreator", fields: [creator_id], references: [id])
  updater_id         String
  updater            user                @relation("SupplyPoolUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model supply_request {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  quantity           Int
  supply_allocations supply_allocation[]
  created_at         DateTime            @default(now()) @db.Timestamptz(0)
  updated_at         DateTime            @updatedAt @db.Timestamptz(0)
  creator_id         String
  creator            user                @relation("SupplyRequestCreator", fields: [creator_id], references: [id])
  updater_id         String
  updater            user                @relation("SupplyRequestUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model supply_allocation {
  id                String         @id @default(cuid())
  supply_request_id String
  supply_request    supply_request @relation(fields: [supply_request_id], references: [id], onDelete: Cascade)
  supply_pool_id    String
  supply_pool       supply_pool    @relation(fields: [supply_pool_id], references: [id])
  quantity          Int
  created_at        DateTime       @default(now()) @db.Timestamptz(0)

  @@index([supply_request_id])
  @@index([supply_pool_id])
}

// ============================================================
// Cell 3: item mode, no lines (room_reservation example)
// ============================================================

model room_type {
  id                String             @id @default(cuid())
  name              String
  capacity          Int?
  description       String?
  rooms             room[]
  room_reservations room_reservation[]
  created_at        DateTime           @default(now()) @db.Timestamptz(0)
  updated_at        DateTime           @updatedAt @db.Timestamptz(0)
  creator_id        String
  creator           user               @relation("RoomTypeCreator", fields: [creator_id], references: [id])
  updater_id        String
  updater           user               @relation("RoomTypeUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model room {
  id                String             @id @default(cuid())
  room_no           String
  room_type_id      String
  room_type         room_type          @relation(fields: [room_type_id], references: [id], onDelete: Cascade)
  floor             Int?
  status            Int                @default(0)
  room_reservations room_reservation[]
  created_at        DateTime           @default(now()) @db.Timestamptz(0)
  updated_at        DateTime           @updatedAt @db.Timestamptz(0)
  creator_id        String
  creator           user               @relation("RoomCreator", fields: [creator_id], references: [id])
  updater_id        String
  updater           user               @relation("RoomUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model room_reservation {
  id           String    @id @default(cuid())
  guest_name   String
  room_type_id String
  room_type    room_type @relation(fields: [room_type_id], references: [id])
  room_id      String?
  room         room?     @relation(fields: [room_id], references: [id])
  check_in     DateTime  @db.Timestamptz(0)
  check_out    DateTime  @db.Timestamptz(0)
  created_at   DateTime  @default(now()) @db.Timestamptz(0)
  updated_at   DateTime  @updatedAt @db.Timestamptz(0)
  creator_id   String
  creator      user      @relation("RoomReservationCreator", fields: [creator_id], references: [id])
  updater_id   String
  updater      user      @relation("RoomReservationUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

// ============================================================
// x-receiving: Receiving lifecycle (PO / ASN / Receipt)
// ============================================================

model receiving_purchase_order {
  id                             String                           @id @default(cuid())
  order_no                       String
  status                         String                           @default("draft")
  lines                          receiving_purchase_order_line[]
  receiving_asns                 receiving_asn[]
  receiving_receipts             receiving_receipt[]
  created_at                     DateTime                         @default(now()) @db.Timestamptz(0)
  updated_at                     DateTime                         @updatedAt @db.Timestamptz(0)
  creator_id                     String
  creator                        user                             @relation("ReceivingPurchaseOrderCreator", fields: [creator_id], references: [id])
  updater_id                     String
  updater                        user                             @relation("ReceivingPurchaseOrderUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
}

model receiving_purchase_order_line {
  id                          String                   @id @default(cuid())
  receiving_purchase_order_id String
  receiving_purchase_order    receiving_purchase_order @relation(fields: [receiving_purchase_order_id], references: [id], onDelete: Cascade)
  product_id                  String
  product                     product                  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  ordered_quantity            Int
  done_quantity               Int                      @default(0)
  cancelled_quantity          Int                      @default(0)
  outstanding_quantity        Int                      @default(0)
  status                      String                   @default("outstanding")
  created_at                  DateTime                 @default(now()) @db.Timestamptz(0)
  updated_at                  DateTime                 @updatedAt @db.Timestamptz(0)

  @@index([receiving_purchase_order_id])
}

model receiving_asn {
  id                 String                    @id @default(cuid())
  asn_no             String
  purchase_order_id  String?
  purchase_order     receiving_purchase_order? @relation(fields: [purchase_order_id], references: [id])
  status             String                    @default("draft")
  lines              receiving_asn_line[]
  receiving_receipts receiving_receipt[]
  created_at         DateTime                  @default(now()) @db.Timestamptz(0)
  updated_at         DateTime                  @updatedAt @db.Timestamptz(0)
  creator_id         String
  creator            user                      @relation("ReceivingAsnCreator", fields: [creator_id], references: [id])
  updater_id         String
  updater            user                      @relation("ReceivingAsnUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
  @@index([purchase_order_id])
}

model receiving_asn_line {
  id                   String        @id @default(cuid())
  receiving_asn_id     String
  receiving_asn        receiving_asn @relation(fields: [receiving_asn_id], references: [id], onDelete: Cascade)
  product_id           String
  product              product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  shipped_quantity     Int
  done_quantity        Int           @default(0)
  cancelled_quantity   Int           @default(0)
  outstanding_quantity Int           @default(0)
  status               String        @default("outstanding")
  created_at           DateTime      @default(now()) @db.Timestamptz(0)
  updated_at           DateTime      @updatedAt @db.Timestamptz(0)

  @@index([receiving_asn_id])
}

model receiving_receipt {
  id                String                    @id @default(cuid())
  receipt_no        String
  purchase_order_id String?
  purchase_order    receiving_purchase_order? @relation(fields: [purchase_order_id], references: [id])
  asn_id            String?
  asn               receiving_asn?            @relation(fields: [asn_id], references: [id])
  status            String                    @default("draft")
  confirmed_at      DateTime?                 @db.Timestamptz(0)
  lines             receiving_receipt_line[]
  created_at        DateTime                  @default(now()) @db.Timestamptz(0)
  updated_at        DateTime                  @updatedAt @db.Timestamptz(0)
  creator_id        String
  creator           user                      @relation("ReceivingReceiptCreator", fields: [creator_id], references: [id])
  updater_id        String
  updater           user                      @relation("ReceivingReceiptUpdater", fields: [updater_id], references: [id])

  @@index([creator_id])
  @@index([purchase_order_id])
  @@index([asn_id])
}

model receiving_receipt_line {
  id                   String            @id @default(cuid())
  receiving_receipt_id String
  receiving_receipt    receiving_receipt @relation(fields: [receiving_receipt_id], references: [id], onDelete: Cascade)
  product_id           String
  product              product           @relation(fields: [product_id], references: [id], onDelete: Cascade)
  receipt_quantity     Int
  done_quantity        Int               @default(0)
  cancelled_quantity   Int               @default(0)
  outstanding_quantity Int               @default(0)
  created_at           DateTime          @default(now()) @db.Timestamptz(0)
  updated_at           DateTime          @updatedAt @db.Timestamptz(0)

  @@index([receiving_receipt_id])
}
